{
  "name": "@mycobrain/mcp-server",
  "version": "1.2.9",
  "mcpName": "io.github.thegoodguysla/myco-brain",
  "description": "Self-hosted memory layer for AI agents — MCP server backed by Postgres + pgvector + knowledge graph",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mycobrain-mcp": "dist/index.js",
    "mycobrain-ingest": "dist/ingest-cli.js",
    "mycobrain-install": "dist/install.js",
    "mycobrain-setup": "dist/guided-install.js",
    "mycobrain-onboard": "dist/onboard.js",
    "mycobrain-doctor": "dist/doctor.js",
    "mycobrain-review": "dist/review.js",
    "mycobrain-rest": "dist/rest-server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thegoodguysla/myco-brain.git"
  },
  "homepage": "https://github.com/thegoodguysla/myco-brain",
  "bugs": {
    "url": "https://github.com/thegoodguysla/myco-brain/issues"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agents",
    "claude",
    "cursor",
    "knowledge-graph",
    "postgres",
    "pgvector",
    "llm"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "dev:sse": "tsx watch src/index-sse.ts",
    "start": "node dist/index.js",
    "start:sse": "node dist/index-sse.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts src/smoke-test.e2e.ts",
    "test:e2e:memory": "vitest run --config vitest.e2e.config.ts src/smoke-memory.e2e.ts",
    "test:direction": "node test/extraction-direction-check.mjs",
    "test:reliability": "node test/extraction-reliability-check.mjs",
    "test:contradiction": "node test/contradiction-hardening-check.mjs",
    "test:proposal-sources": "node test/proposal-sources-check.mjs",
    "test:dynamic-schema": "node test/dynamic-schema-check.mjs",
    "test:strict-mode": "node test/strict-mode-check.mjs",
    "test:local-embeddings": "node test/local-embeddings-check.mjs",
    "test:load:get-related": "tsx src/get-related.load.ts",
    "worker:extract": "tsx src/extraction-worker.ts",
    "migrate": "node dist/migrate.js",
    "test:sharing": "node test/sharing-check.mjs",
    "test:compounding": "node test/compounding-confidence-check.mjs",
    "test:schema-promotion": "node test/schema-promotion-check.mjs",
    "audit:tokens": "node test/tool-token-audit.mjs",
    "test:agency": "node test/agency-isolation-check.mjs",
    "test:review": "node test/review-check.mjs",
    "test:rest": "node test/rest-check.mjs",
    "rest": "node dist/rest-server.js",
    "demo:render": "bash ../demos/render.sh",
    "test:export-import": "node test/export-import-check.mjs",
    "test:rls": "node test/rls-least-privilege-check.mjs",
    "test:import-embeddings": "node test/import-embeddings-check.mjs",
    "test:onboard": "node test/onboard-check.mjs",
    "test:install": "node test/install-check.mjs",
    "test:attribution": "node test/attribution-check.mjs",
    "test:milestones": "node test/milestones-check.mjs",
    "test:export-detect": "node test/export-detect-check.mjs",
    "test:doctor": "node test/doctor-check.mjs",
    "check:contract-drift": "node eval/agent-contract/drift-guard.mjs",
    "eval:contract": "node eval/agent-contract/run.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "gpt-tokenizer": "^3.4.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
