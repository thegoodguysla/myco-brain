FROM node:20-slim AS builder

WORKDIR /app

COPY package.json .
RUN npm install

COPY tsconfig.json .
COPY src ./src

RUN npm run build
RUN npm prune --omit=dev

FROM node:20-slim

WORKDIR /app

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json .

CMD ["node", "dist/index-sse.js"]

# For Railway deployment (where migrations are available), use Dockerfile.railway at the repo root.

