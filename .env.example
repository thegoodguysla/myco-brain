# ── Required ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brain:brain@localhost:5432/brain
# Defaults below match the seeded local workspace/agent (see migration
# 20260601000045_seed_default_local_workspace.sql). Use them as-is for the
# quickstart, or swap in your own provisioned workspace/agent UUIDs.
# Key format: brain_<workspaceId>_<agentId>_<secret> — both ids must be UUIDs.
BRAIN_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
BRAIN_API_KEY=brain_00000000-0000-0000-0000-000000000001_00000000-0000-0000-0000-0000000000a1_localdev

# ── Optional: vector embeddings (semantic search) ─────────────────────────────
# When set, brain.search and brain.context_pack auto-embed queries via
# OpenAI text-embedding-3-small (1536d). BM25 full-text search works without this.
BRAIN_OPENAI_API_KEY=sk-...

# ── Optional: knowledge-graph extraction worker ───────────────────────────────
# The extraction worker reads ingested chunks and extracts entities into a
# queryable graph. Pick ONE provider (without either, content is still fully
# searchable via BM25 — you just don't get the entity graph):
#
# Option A — Local & free via Ollama (no API key). Install Ollama, then:
#   ollama pull llama3.2:3b
# Set the base URL (from Docker, use http://host.docker.internal:11434):
BRAIN_OLLAMA_BASE_URL=
BRAIN_OLLAMA_MODEL=llama3.2:3b
#
# Option B — Hosted via Anthropic Claude:
BRAIN_ANTHROPIC_API_KEY=sk-ant-...
#
# Provider precedence: Anthropic key (if set) → Ollama (if base URL set) → none.
# Force one explicitly with BRAIN_EXTRACTION_PROVIDER=ollama|anthropic.

# ── Optional: Cohere Rerank ────────────────────────────────────────────────────
BRAIN_COHERE_API_KEY=

# ── Optional: health endpoint ─────────────────────────────────────────────────
# Exposes GET /health on this port (used by Railway, Docker healthcheck, etc.)
BRAIN_HEALTH_PORT=8080
