# ── Required ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brain:brain@localhost:5432/brain
# Defaults below match the seeded local workspace/agent (see migration
# 20260601000045_seed_default_local_workspace.sql). Use them as-is for the
# quickstart, or swap in your own provisioned workspace/agent UUIDs.
# Key format: brain_<workspaceId>_<agentId>_<secret> — both ids must be UUIDs.
BRAIN_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
BRAIN_API_KEY=brain_00000000-0000-0000-0000-000000000001_00000000-0000-0000-0000-0000000000a1_localdev

# ── Optional: vector embeddings (semantic search) ─────────────────────────────
# brain_search and brain_context_pack auto-embed queries for semantic search.
# Without a provider, BM25 full-text search still works (vector_used: false).
# Pick ONE provider:
#
# Option A — Local & free via Ollama (no API key). Install Ollama, then:
#   ollama pull nomic-embed-text
# Set BRAIN_EMBED_PROVIDER=ollama and the base URL (from Docker, use
# http://host.docker.internal:11434; defaults to http://localhost:11434):
BRAIN_EMBED_PROVIDER=
# BRAIN_OLLAMA_BASE_URL is shared with the extraction worker (set below).
BRAIN_OLLAMA_EMBED_MODEL=nomic-embed-text
#
# Option B — OpenAI text-embedding-3-small (1536d). Uncomment and set:
# BRAIN_OPENAI_API_KEY=sk-...
#
# Selection: BRAIN_EMBED_PROVIDER=openai|ollama forces one; otherwise auto —
# OpenAI when a key is set, else Ollama when a base URL is set. The two
# providers use different vector dimensions and separate tables, so configure
# the provider before ingesting (re-embed if you switch).

# ── Optional: knowledge-graph extraction worker ───────────────────────────────
# The extraction worker reads ingested chunks and extracts entities into a
# queryable graph. Pick ONE provider (without either, content is still fully
# searchable via BM25 — you just don't get the entity graph):
#
# Option A — Local & free via Ollama (no API key). Install Ollama, then:
#   ollama pull llama3.2:3b
# Set the base URL (from Docker, use http://host.docker.internal:11434):
BRAIN_OLLAMA_BASE_URL=
BRAIN_OLLAMA_MODEL=llama3.2:3b
#
# Option B — Hosted via Anthropic Claude. Uncomment and set:
# BRAIN_ANTHROPIC_API_KEY=sk-ant-...
#
# Provider precedence: Anthropic key (if set) → Ollama (if base URL set) → none.
# Force one explicitly with BRAIN_EXTRACTION_PROVIDER=ollama|anthropic.
#
# Dynamic schema (phase 1): the worker records entity kinds / relationship
# types it observes that aren't in the catalogs as pending schema_proposals
# (surfaced by brain_stats; promotion is manual). Minimum confidence to
# propose (0-1, default 0.6):
# BRAIN_SCHEMA_PROPOSAL_MIN_CONFIDENCE=0.6
#
# Strict curation mode: NOTHING the LLM proposes is auto-promoted into the
# canonical graph — every entity and relation waits in the review queue
# (proposed_*, state=pending) for a human decision. The LLM writes proposals;
# the human writes the graph. Note: relations queue only between entities
# that already exist in the canonical graph.
# BRAIN_REQUIRE_HUMAN_REVIEW=1
#
# Full dynamic schema: let corroborated proposals AUTO-PROMOTE into the live
# catalogs (entity_kinds / relation_types). Default OFF — proposals wait for
# manual review. A type promotes when seen in enough DISTINCT documents at
# high enough confidence; strict curation mode always wins.
# BRAIN_SCHEMA_AUTO_PROMOTE=1
# BRAIN_SCHEMA_PROMOTE_MIN_SEEN=3
# BRAIN_SCHEMA_PROMOTE_MIN_CONFIDENCE=0.8
#
# Compounding confidence: predicates where a subject has exactly ONE current
# object ("functional"). A confident new observation on one of these
# supersedes a conflicting old fact (closes + weakens it — never overwrites).
# Defaults: works for, reports to, located in. Extend (comma-separated,
# ASSIGNED_TO-style naming ok):
# BRAIN_FUNCTIONAL_PREDICATES=married to,ceo of

# ── Optional: Cohere Rerank ────────────────────────────────────────────────────
BRAIN_COHERE_API_KEY=

# ── Optional: health endpoint ─────────────────────────────────────────────────
# Exposes GET /health on this port (used by Railway, Docker healthcheck, etc.)
BRAIN_HEALTH_PORT=8080
